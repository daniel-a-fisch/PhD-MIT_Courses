bs=c(8,20,30,34)#
quartz(height=8,width=8)#
par(mfrow=c(2,2))#
#
for (b in bs) {#
lo=runif(1000,0,b-1)#
hi=runif(1000,b+1,40)#
#
gdd1=gdd2=tavgs=c()#
for (i in 1:1000) {#
tavg=(hi[i]+lo[i])/2#
tavgs=c(tavgs,tavg)#
if (tavg>b) {add1=tavg-b #
} else {add1=0}#
gdd1=c(gdd1,add1)#
x=acos((2*b-hi[i]-lo[i])/(hi[i]-lo[i]))#
add2=((tavg-b)*x + (hi[i]-lo[i])*sin(x)/2)/pi#
gdd2=c(gdd2,add2)#
}#
#
plot(gdd1,gdd2,main=paste("bound = ",b,sep=""))#
cor(gdd1,gdd2)#
}
?runif
length(lo)
hist(lo)
runif(10,0,1)
length(tavgs)
corr(gdd1,gdd2,tavgs)
cor(gdd1,gdd2)
cor(gdd1,tavgs)
plot(gdd1,tavgs)
